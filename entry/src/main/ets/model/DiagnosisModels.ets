/** Stable source values used by diagnosis domain models and persisted reports. */
export enum SourceType {
  IMAGE = 'IMAGE',
  TEXT = 'TEXT'
}

/**
 * In-memory input for one diagnosis session.
 *
 * `sessionId` is a non-empty identifier generated by the session layer.
 * `createdAt` is Unix time in milliseconds. This model is not persisted;
 * in particular, `imageUri` must never be copied into diagnosis history.
 */
export interface DiagnosisInput {
  sessionId: string;
  sourceType: SourceType;
  rawText: string;
  imageUri?: string;
  createdAt: number;
}

/**
 * Domain report produced by the local diagnosis engine.
 *
 * `id` is a non-empty local identifier and all time fields are Unix
 * milliseconds. Optional collections stay `undefined` in the domain model;
 * a later storage adapter is responsible for its documented `[]` mapping.
 * The model contains sensitive `rawText` and `evidence` and must not be logged.
 */
export interface DiagnosisReport {
  id: string;
  errorType: string;
  secondaryTags?: Array<string>;
  summary: string;
  evidence: Array<string>;
  possibleCauses: Array<string>;
  steps: Array<string>;
  suggestions?: Array<string>;
  riskNotice?: string;
  rawText: string;
  sourceType: SourceType;
  createdAt: number;
  savedAt?: number;
  isFavorite: boolean;
  engineVersion: string;
}

/** Versioned rule loaded from a bundled read-only resource. */
export interface DiagnosisRule {
  ruleId: string;
  errorType: string;
  keywords: Array<string>;
  patterns: Array<string>;
  priority: number;
  summaryTemplate: string;
  causes: Array<string>;
  steps: Array<string>;
  riskNotice?: string;
  version: string;
}
